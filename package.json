{
  "name": "alun-reader",
  "productName": "alun reader",
  "description": "A cross-platform desktop Markdown and Mermaid reader.",
  "private": true,
  "version": "1.0.0",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "desktop": "npm run build && electron .",
    "build": "vite build",
    "build:desktop": "npm run build && electron-builder -mwl",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "package:mac": "bash scripts/package-desktop.sh mac",
    "package:win": "bash scripts/package-desktop.sh win",
    "package:linux": "bash scripts/package-desktop.sh linux",
    "package:all": "bash scripts/package-desktop.sh all",
    "release:publish": "node scripts/publish-release.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.alun.reader",
    "productName": "alun reader",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Office",
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.15.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
